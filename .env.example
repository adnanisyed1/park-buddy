# Park Buddy — environment variables reference.
# Copy the NAMES into Vercel (Project → Settings → Environment Variables) and fill
# the values from your existing Netlify env vars. This file documents them; it holds
# NO real secrets and is safe to commit. For local dev, copy to `.env.local` and fill.
#
# NEXT_PUBLIC_* are exposed to the browser (safe to be public). Everything else is
# server-only and must NEVER be prefixed NEXT_PUBLIC_ or shipped to the client.

# ── Core secrets (required) ──────────────────────────────────────────────────
NPS_API_KEY=                     # developer.nps.gov — parks/alerts/webcams/thingstodo/roadstatus
ANTHROPIC_API_KEY=               # console.anthropic.com — the /api/agent assistant
AIRNOW_API_KEY=                  # docs.airnowapi.org — air quality
RIDB_API_KEY=                    # ridb.recreation.gov — campgrounds/facilities

# ── Google Maps (required; public, but restrict it by HTTP referrer) ─────────
NEXT_PUBLIC_GMAPS_KEY=           # Maps JS + Elevation API enabled; restrict to your domains

# ── Supabase (required — cache, reviews, agent rate-limiter pb_kv) ───────────
SUPABASE_URL=                    # https://xxxx.supabase.co  (no /rest/v1 suffix)
SUPABASE_SERVICE_KEY=            # service_role key — SERVER ONLY, bypasses RLS
SUPABASE_ANON_KEY=               # anon public key (server-side reads)
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # same anon key, for the browser client (auth.js)

# ── Site / canonical (required for correct SEO + absolute URLs) ──────────────
NEXT_PUBLIC_SITE_URL=            # the URL CURRENTLY serving: the *.vercel.app URL pre-launch,
                                 # then https://theparkbuddy.com once the domain is attached

# ── Cron + ingest (recommended) ──────────────────────────────────────────────
CRON_SECRET=                     # any random string; Vercel sends it as a Bearer header to
                                 # /api/cron/ingest so only Vercel Cron can trigger the job
INGEST_SECRET=                   # optional shared secret guarding /api/ingest (?token=...)

# ── Optional tuning (defaults are sensible; only set to override) ─────────────
# AGENT_RATE_LIMIT=8             # agent requests per window per IP
# AGENT_RATE_WINDOW_MS=60000
# AGENT_DAILY_REQUESTS=5000      # global daily request cap
# AGENT_DAILY_USD=10             # global daily spend cap (USD)
# NEXT_PUBLIC_ASSET_VERSION=     # cache-bust static assets on deploy

# ── Set automatically by the host — DO NOT set these yourself ────────────────
# VERCEL     — Vercel sets this to "1" in every deployment (used for API-key gating)
# NETLIFY    — legacy; only present on the retiring Netlify deploy

# ── Transactional email (order confirmation + shipping notice) ────────────────
# Without these an order still fulfils, but the customer is never emailed. The
# webhook logs "confirmation not sent: RESEND_API_KEY not set" rather than failing.
RESEND_API_KEY=
MAIL_FROM="Park Buddy <orders@theparkbuddy.com>"

# Shared secret for the tracking poller. GET /api/order-tracking?key=<this>.
# Without it the endpoint 404s, so it can't be triggered by anyone who finds the URL.
# Run it on a schedule (Vercel Cron); every few hours is plenty.
ORDER_CRON_SECRET=

# Order desk (/admin/orders) — lists customer emails, so treat like a password.
# Without it the screen and its API return "isn't configured" rather than opening.
ORDERS_ADMIN_SECRET=
