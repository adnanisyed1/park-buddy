{"id":"ashley-river-road","generatedAt":"2026-07-10T18:35:17.820Z","designation":"National Scenic Byway","parkCode":null,"source":{"roadArticle":"South Carolina Highway 61","revisionId":1352203830,"url":"https://en.wikipedia.org/wiki/South_Carolina_Highway_61"},"attribution":{"license":"CC BY-SA 4.0","licenseUrl":"https://creativecommons.org/licenses/by-sa/4.0/","articleUrl":"https://en.wikipedia.org/wiki/South_Carolina_Highway_61","text":"Route, junction, and history details adapted from the Wikipedia article \"South Carolina Highway 61\", by Wikipedia contributors, licensed under CC BY-SA 4.0."},"sources":[{"name":"Wikipedia","src":"wikipedia","url":"https://en.wikipedia.org/wiki/South_Carolina_Highway_61","revisionId":1352203830,"retrievedAt":"2026-07-10T18:35:17.820Z"},{"name":"Federal Highway Administration — National Scenic Byways","src":"fhwa","url":"https://www.fhwa.dot.gov/byways","retrievedAt":"2026-07-10T18:35:17.820Z"},{"name":"OpenStreetMap contributors (ODbL)","src":"osm","url":"https://www.openstreetmap.org/copyright","retrievedAt":"2026-07-10T18:35:17.820Z"}],"endpoints":{"from":"Charleston, SC","to":"Whetstone Crossroads, SC","via":["Cooks Crossroads, SC","Givhans, SC","Canadys, SC"]},"itinerary":[{"seq":1,"place":"Charleston","state":"SC","kind":"terminus","mileFromStart":0,"toNextMi":19.5,"note":"The drive begins here","control":["Folly Beach","Calhoun Street","SC 171 south (Wesley Drive)","SC 171 north (St. Andrews Boulevard","Old Towne Boulevard) to I-26","SC 7 (Sam Rittenberg Boulevard)","SC 61 Conn. begins","SC 461 north (Paul Cantrell Boulevard)","SC 61 Conn. ends"],"lat":32.82487,"lng":-80.03869,"src":"wikipedia"},{"seq":2,"place":"Cooks Crossroads","state":"SC","kind":"town","mileFromStart":19.5,"toNextMi":9.9,"note":"Junction toward Ravenel & Summerville","control":["Ravenel","Summerville"],"lat":null,"lng":null,"src":"wikipedia"},{"seq":3,"place":"Givhans","state":"SC","kind":"town","mileFromStart":29.4,"toNextMi":17.5,"note":"Junction toward Ridgeville","control":["Ridgeville"],"lat":null,"lng":null,"src":"wikipedia"},{"seq":4,"place":"Canadys","state":"SC","kind":"town","mileFromStart":46.9,"toNextMi":13.7,"note":"Junction toward Walterboro & St. George","control":["Walterboro","St. George"],"lat":32.94753,"lng":-80.20401,"src":"wikipedia"},{"seq":5,"place":"Whetstone Crossroads","state":"SC","kind":"terminus","mileFromStart":60.6,"toNextMi":null,"note":"The drive ends here","control":["Branchville","Beaufort"],"lat":null,"lng":null,"src":"wikipedia"}],"history":{"paragraphs":["South Carolina Highway 65 (SC 65) was a state highway that existed in the southeastern part of Bamberg County, the northern part of Colleton County, and the southern part of Dorchester County. It was established in 1929 from U.S. Route 78 (US 78; now Farrells Road) in Farrells Crossroads to SC 64 southeast of Givhans. It was also proposed to continue to the southeast to meet SC 61 (now SC 165 Connector). In 1932, the proposed portion was shifted to the northeast, to follow SC 64 across the Ashley River and then southeast to meet SC 61 (now SC 165 south of Summerville. In 1933, the highway was extended northwest and north-northwest, following US 78 until they met the U.S. Highway's new routing west-southwest of Branchville. Also, its proposed path near Summerville was completed. In December 1950, it was rerouted onto its 1929 path, replacing SC 650 to end at SC 61 (now SC 165 Conn.) in Cooks Crossroads. The portion of the former path not concurrent with SC 64 was redesignated as SC 642. In 1952, SC 65 was redesignated as SC 61."],"sourceSection":"History","src":"wikipedia"},"highlights":[{"n":"Charleston","d":"The drive begins here","q":"Charleston","lat":32.81388889,"lng":-79.93194444,"src":"wikipedia"}],"references":[{"n":1,"text":"\"Statewide Highways (shapefile)\" (zip). South Carolina Department of Transportation. September 29, 2017. Retrieved December 8, 2017.","url":"http://info2.scdot.org/sites/GIS/GISMapdl/Statewide_Highways.zip"},{"n":2,"text":"\"Bill Information – South Carolina Legislature Online\".","url":"http://scstatehouse.net/cgi-bin/web_bh10.exe?bill1=1188&session=112"},{"n":3,"text":"\"Ashley River Road\". National Scenic Byway Foundation. May 2, 2026. Retrieved May 2, 2026.","url":"https://nsbfoundation.com/nb/ashley-river-road/"},{"n":4,"text":"\"National Register Information System\". National Register of Historic Places. National Park Service. July 9, 2010.","url":"https://npgallery.nps.gov/NRHP"},{"n":5,"text":"Wylie, Suzanne Pickens; Norman McCorkle (August 23, 1983). \"Ashley River Road\" (PDF). National Register of Historic Places - Nomination and Inventory. Retrieved June 9, 2012.","url":"http://www.nationalregister.sc.gov/charleston/S10817710138/S10817710138.pdf"},{"n":6,"text":"\"Ashley River Road, Charleston County (S.C. Hwy. 61 btw. Church Creek & S.C. Hwy. 165, Charleston & Summerville vicinities, Charleston & Dorchester Counties)\". National Register Properties in South Carolina. South Carolina Department of Archives and History. Retrieved June 9, 201","url":"http://www.nationalregister.sc.gov/charleston/S10817710138/index.htm"},{"n":7,"text":"\"A hurrah for Watson Hill\". Post and Courier. Archived from the original on October 6, 2011.","url":"https://web.archive.org/web/20111006124243/http://www.postandcourier.com/news/2009/aug/03/a-hurrah-for-watson-hill/"},{"n":8,"text":"\"Public weighs in on Watson Hill\". Post and Courier. Archived from the original on October 6, 2011.","url":"https://web.archive.org/web/20111006124250/http://www.postandcourier.com/news/2009/jul/31/public-weighs-in-on-watson-hill/"}],"routeLine":[[32.82487,-80.03869],[32.82554,-80.0392],[32.82613,-80.03966],[32.82689,-80.04025],[32.82748,-80.04069],[32.82843,-80.04141],[32.82925,-80.042],[32.82989,-80.04247],[32.83043,-80.04288],[32.83098,-80.04331],[32.83163,-80.04379],[32.8323,-80.04427],[32.83283,-80.04467],[32.83367,-80.04528],[32.83422,-80.04573],[32.83494,-80.04631],[32.835