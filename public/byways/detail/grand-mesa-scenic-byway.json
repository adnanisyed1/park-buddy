{"id":"grand-mesa-scenic-byway","generatedAt":"2026-07-10T18:35:17.820Z","designation":"National Scenic Byway","parkCode":null,"source":{"roadArticle":"Colorado State Highway 65","revisionId":1290149527,"url":"https://en.wikipedia.org/wiki/Colorado_State_Highway_65"},"attribution":{"license":"CC BY-SA 4.0","licenseUrl":"https://creativecommons.org/licenses/by-sa/4.0/","articleUrl":"https://en.wikipedia.org/wiki/Colorado_State_Highway_65","text":"Route, junction, and history details adapted from the Wikipedia article \"Colorado State Highway 65\", by Wikipedia contributors, licensed under CC BY-SA 4.0."},"sources":[{"name":"Wikipedia","src":"wikipedia","url":"https://en.wikipedia.org/wiki/Colorado_State_Highway_65","revisionId":1290149527,"retrievedAt":"2026-07-10T18:35:17.820Z"},{"name":"Federal Highway Administration — National Scenic Byways","src":"fhwa","url":"https://www.fhwa.dot.gov/byways","retrievedAt":"2026-07-10T18:35:17.820Z"},{"name":"OpenStreetMap contributors (ODbL)","src":"osm","url":"https://www.openstreetmap.org/copyright","retrievedAt":"2026-07-10T18:35:17.820Z"}],"endpoints":{"from":"Saunders, CO","to":"Cedaredge, CO","via":[]},"itinerary":[{"place":"Colorado State Highway 65 (start)","mileFromStart":0,"kind":"terminus","lat":38.90074,"lng":-107.92376,"seq":1,"src":"openstreetmap","control":[],"note":"The drive begins here","toNextMi":18.4},{"place":"Land of Lakes Overlook","mileFromStart":18.4,"kind":"overlook","lat":39.02905,"lng":-108.01905,"seq":2,"src":"openstreetmap","control":[],"note":"","toNextMi":0},{"place":"Scenic overlook","mileFromStart":18.4,"kind":"overlook","lat":39.02897,"lng":-108.01914,"seq":3,"src":"openstreetmap","control":[],"note":"","toNextMi":32},{"place":"Colorado State Highway 65 (end)","mileFromStart":50.4,"kind":"terminus","lat":39.1826,"lng":-108.28134,"seq":4,"src":"openstreetmap","control":[],"note":"The drive ends here"}],"history":{"paragraphs":["SH 65 runs 61.4 miles (98.8 km), starting at a junction with SH 92 east of Delta. The highway heads north, crossing the Gunnison River, through Orchard City and Cedaredge. The highway then enters Grand Mesa National Forest climbing to the top of Grand Mesa. It then drops down the north side of Grand Mesa, ending at a junction with I-70 northeast of Palisade.","The byway runs north from Cedaredge along Highway 65, to the top of the Grand Mesa at more than 10,000 feet (3,000 m). It also includes Land's End Road to the Land's End Observatory from Highway 65. The byway continues past Island Lake, one of more than 300 trout-filled lakes in Grand Mesa National Forest. On the north side of the Mesa are the towns of Mesa, Collbran, and Powderhorn Ski Resort. The byway continues along De Beque Canyon, with its colorful sandstone bluffs, and eventually meets Interstate 70 in the town of De Beque."],"sourceSection":"Route description","src":"wikipedia"},"highlights":[{"n":"Cedaredge","d":"The drive ends here","q":"Cedaredge","lat":38.9016,"lng":-107.9265,"src":"wikipedia"}],"references":[{"n":1,"text":"\"Segment list for SH 65\". Retrieved January 21, 2011.[permanent dead link]","url":"http://www.dot.state.co.us/app_DTD_DataAccess/Highways/index.cfm?fuseaction=Description&route=65&begRefPt=0&endRefPt=500&Printable=true"},{"n":2,"text":"\"Grand Mesa Scenic and Historic Byway\". America's Byways. Archived from the original on November 24, 2010. Retrieved January 21, 2011.","url":"https://web.archive.org/web/20101124211204/http://byways.org/explore/byways/2103/"},{"n":3,"text":"Grand Mesa Scenic Byway Grand Mesa Scenic and Historic Byway Association. 2010-2011.","url":"https://archive.today/20130616090858/http://www.grandmesabyway.com/"},{"n":4,"text":"Grand Mesa Scenic Byway Map Grand Mesa Scenic and Historic Byway Association. 2010-2011.","url":"https://web.archive.org/web/20130915094358/http://grandmesabyway.com/Get-Involved.html"}],"routeLine":[[38.90074,-107.92376],[38.90183,-107.92376],[38.90334,-107.92379],[38.90407,-107.9238],[38.90466,-1