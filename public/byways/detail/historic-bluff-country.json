ileFromStart":87.7,"toNextMi":1.8,"note":"Crosses Great River","control":["Winona"],"lat":43.83,"lng":-91.30444444,"src":"wikipedia"},{"seq":15,"place":"Mississippi River","state":"MN","kind":"terminus","mileFromStart":89.5,"toNextMi":null,"note":"The drive ends here","control":["La Crosse West Channel Bridge","La Crosse"],"lat":null,"lng":null,"src":"wikipedia"}],"history":{"paragraphs":["State Highway 16 was designated in 1980. The route was originally part of old U.S. Highway 16 from 1926 to 1980.","U.S. 16 was mostly replaced by Interstate Highway 90 within Minnesota.","State Highway 16 from Dexter to La Crescent is the only remaining section of this former U.S. route that exists as a trunk highway separate from Interstate 90.","After crossing the Mississippi River Bridge and the Wisconsin state line, old U.S. 16 continues on as Wisconsin Highway 16."],"sourceSection":"History","src":"wikipedia"},"highlights":[{"n":"Dexter","d":"The drive begins here","q":"Dexter","lat":43.71888889,"lng":-92.70472222,"src":"wikipedia"},{"n":"La Crescent Township","d":"Crosses Great River","q":"La Crescent Township","lat":43.82361111,"lng":-91.32972222,"src":"wikipedia"},{"n":"La Crescent","d":"Crosses Great River","q":"La Crescent","lat":43.83,"lng":-91.30444444,"src":"wikipedia"}],"references":[{"n":1,"text":"Riner, Steve. \"Details of Routes 1-25\". The Unofficial Minnesota Highways Page. Retrieved March 12, 2006.[self-published source?]","url":"http://www.steve-riner.com/mnhighways/r1-25.htm#16"},{"n":2,"text":"Minnesota Department of Transportation. \"Statewide Trunk Logpoint Listing\" (PDF). St. Paul: Minnesota Department of Transportation. Retrieved September 2, 2015.","url":"http://www.dot.state.mn.us/roadway/data/reports/logpt/statelpt.pdf"},{"n":3,"text":"Highways and Gas Stations - MN State Highway 16 page Archived March 2, 2012, at the Wayback Machine","url":"http://www.public.iastate.edu/~pmjohns/hwgs/"}]}