47.29627,"lng":-91.25606,"src":"wikipedia"},{"seq":4,"place":"Illgen City","state":"MN","kind":"town","mileFromStart":59.3,"toNextMi":6,"note":"Junction toward Ely","control":["Ely"],"lat":47.34684,"lng":-91.18726,"src":"wikipedia"},{"seq":5,"place":"Little Marais","state":"MN","kind":"town","mileFromStart":65.3,"toNextMi":17.4,"note":"Junction toward Little Marais Road (CSAH 6)","control":["Little Marais Road (CSAH 6)"],"lat":47.41093,"lng":-91.11043,"src":"wikipedia"},{"seq":6,"place":"Tofte","state":"MN","kind":"town","mileFromStart":82.7,"toNextMi":9.8,"note":"Junction toward Sawbill Trail (CSAH 2)","control":["Sawbill Trail (CSAH 2)"],"lat":47.57406,"lng":-90.83636,"src":"wikipedia"},{"seq":7,"place":"Lutsen","state":"MN","kind":"town","mileFromStart":92.5,"toNextMi":17.8,"note":"Junction toward Caribou Trail (CSAH 4)","control":["Caribou Trail (CSAH 4)"],"lat":47.64708,"lng":-90.6746,"src":"wikipedia"},{"seq":8,"place":"Grand Marais","state":"MN","kind":"town","mileFromStart":110.3,"toNextMi":18.6,"note":"Junction toward Gunflint Trail (CSAH 12)","control":["Gunflint Trail (CSAH 12)"],"lat":47.75055,"lng":-90.33472,"src":"wikipedia"},{"seq":9,"place":"Hovland","state":"MN","kind":"town","mileFromStart":128.9,"toNextMi":22,"note":"Junction toward Arrowhead Trail (CSAH 16)","control":["Arrowhead Trail (CSAH 16)"],"lat":47.83894,"lng":-89.97196,"src":"wikipedia"},{"seq":10,"place":"Pigeon River","state":"MN","kind":"terminus","mileFromStart":150.9,"toNextMi":null,"note":"The drive ends here","control":["Grand Portage–Pigeon River Border Crossing","Thunder Bay"],"lat":47.99913,"lng":-89.59845,"src":"wikipedia"}],"history":{"paragraphs":["Minnesota Highway 61 was designated and signed in 1991. The roadway was originally part of US 61 from 1926 to 1991.","After construction of I-35 in the 1960s, US 61 was co-signed with I-35 until 1991. During that year, US 61 was decommissioned from the Canadian border south to its present-day junction with I-35 at the city of Wyoming near Forest Lake. The section of US 61 north of Duluth was redesignated MN 61 that same year.","MN 61 is one of three state marked highways to carry the same number as an existing U.S. Highway within the state; the others are MN 65 and MN 169.","From 1991 to 1997, MN 61 continued southwest on London Road beyond I-35 to 14th Avenue East, where southbound traffic then turned northwest to end at MN 23 which followed a one-way pair of 2nd Street East (eastbound) and 3rd Street East (westbound); northbound MN 61 began following 12th Avenue East south to London Road. Both routes were turned back to end at their respective I-35 junctions in Duluth in 1997."],"sourceSection":"History","src":"wikipedia"},"highlights":[{"n":"Duluth","d":"The drive begins here","q":"Duluth","lat":46.78444444,"lng":-92.10527778,"src":"wikipedia"},{"n":"Silver Bay","d":"Gateway to Superior National Forest","q":"Silver Bay","lat":47.2925,"lng":-91.27277778,"src":"wikipedia"},{"n":"Pigeon River","d":"The drive ends here","q":"Pigeon River","lat":48.01027778,"lng":-89.70833333,"src":"wikipedia"}],"references":[{"n":1,"text":"\"Trunk Highway Log Point Listing: Construction District 1\" (PDF). Minnesota Department of Transportation. August 20, 2010. Archived from the original (PDF) on December 4, 2008. Retrieved October 24, 2010.","url":"https://web.archive.org/web/20081204174552/http://www.dot.state.mn.us/roadway/data/reports/logpoint/d1.pdf"},{"n":2,"text":"\"Park Info\". state.mn.us. Archived from the original on August 23, 2007. Retrieved August 20, 2007.","url":"http://www.dnr.state.mn.us/state_parks/gooseberry_falls/narrative.html"},{"n":3,"text":"\"Park Info\". state.mn.us. Archived from the original on February 11, 2009. Retrieved August 20, 2007.","url":"https://web.archive.org/web/20090211163459/http://www.dnr.state.mn.us/state_parks/split_rock_lighthouse/narrative.html"},{"n":4,"text":"\"Park Info\". state.mn.us. Archived from the original on August 25, 2007. Retrieved August 20, 2007.