":24.1,"toNextMi":4.1,"note":"Junction toward South Dennis","control":["South Dennis"],"lat":41.74318,"lng":-70.1582,"src":"wikipedia"},{"seq":5,"place":"Brewster","state":"MA","kind":"town","mileFromStart":28.2,"toNextMi":4.8,"note":"Junction toward East Harwich & Chatham","control":["East Harwich","Chatham","Harwich Center","Harwichport"],"lat":41.76044,"lng":-70.08391,"src":"wikipedia"},{"seq":6,"place":"Orleans","state":"MA","kind":"town","mileFromStart":33,"toNextMi":2,"note":"Junction toward Hyannis & New Bedford","control":["Hyannis","New Bedford","Eastham","Provincetown","Chatham","Falmouth"],"lat":41.78957,"lng":-69.98999,"src":"wikipedia"},{"seq":7,"place":"Eastham","state":"MA","kind":"town","mileFromStart":35,"toNextMi":18.6,"note":"Junction toward Hyannis & New Bedford","control":["Hyannis","New Bedford","Eastham","Provincetown"],"lat":41.79865,"lng":-69.98311,"src":"wikipedia"},{"seq":8,"place":"Truro","state":"MA","kind":"town","mileFromStart":53.6,"toNextMi":8.8,"note":"Junction toward Provincetown","control":["Provincetown"],"lat":41.79865,"lng":-69.98311,"src":"wikipedia"},{"seq":9,"place":"Provincetown","state":"MA","kind":"terminus","mileFromStart":62.4,"toNextMi":null,"note":"The drive ends here","control":["New Bedford","Race Point"],"lat":41.79865,"lng":-69.98311,"src":"wikipedia"}],"history":{"paragraphs":["Route 6A was first signed upon partial completion of the Mid-Cape Highway, which was Cape Cod's first freeway in 1953, traveling between the Sagamore Bridge in Bourne and Route 132 in Barnstable.[citation needed] A second stretch in 1954 was signed when a US 6 bypass was constructed in Truro and Provincetown, although in Provincetown, Route 6A was signed along Bradford Street instead of US 6's former routing on Commercial Street, as the latter road had become one-way westbound.[citation needed] A third stretch in 1956 was signed between Route 132 in Barnstable and the Orleans–Eastham town line when the US 6 freeway was completed.[citation needed]","Route 6A does not officially exist in Eastham or Wellfleet as the road is in an unsigned concurrency with US 6.","The road is generally considered to be Cape Cod's most historic and scenic highway. The Barnstable portion has been listed on the National Register of Historic Places as the Old King's Highway Historic District.","The only portions of the Provincetown section under state (or federal) maintenance are the Commercial Street section (including Bradford between Commercial and Allerton) and the Province Lands Road section (which runs through National Park land). The remainder of the Bradford Street section has always been locally maintained, and though that section carries the occasional mile marker from the last postings in 1979, it has always only sparsely been signed as Route 6A.[citation needed]"],"sourceSection":"History","src":"wikipedia"},"highlights":[{"n":"Bourne","d":"The drive begins here","q":"Bourne","lat":41.74111111,"lng":-70.59944444,"src":"wikipedia"},{"n":"Provincetown","d":"The drive ends here","q":"Provincetown","lat":42.058,"lng":-70.179,"src":"wikipedia"}],"references":[{"n":1,"text":"MassDOT Planning Division. \"Massachusetts Route Log Application\". Massachusetts Department of Transportation. Retrieved January 23, 2016.","url":"http://services.massdot.state.ma.us/mrla/MRLAprintRouteLog.htm?routekey=SR6A%20EB/pages=1-35/"},{"n":2,"text":"\"NPGallery Asset Detail\". npgallery.nps.gov. Retrieved June 29, 2025.","url":"https://npgallery.nps.gov/AssetDetail/NRIS/87000314"}],"routeLine":[[41.77345,-70.53972],[41.77313,-70.53874],[41.77287,-70.53789],[41.77269,-70.53712],[41.77247,-70.5362],[41.77222,-70.53518],[41.77198,-70.53411],[41.77174,-70.5332],[41.77143,-70.5321],[41.77115,-70.53136],[41.77075,-70.53056],[41.7705,-70.52983],[41.77029,-70.52898],[41.76998,-70.52816],[41.76973,-70.52743],[41.76951,-70.52667],[41.76925,-70.52582],[41.7689,-70.52475],[41.76859,-70.524],[41.7682,-70.52328],[41.76755,-70.52236],[41.76702,-70.52156]